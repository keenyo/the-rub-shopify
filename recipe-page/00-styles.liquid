{% comment %}
  THE RUB — RECIPE ARTICLE TEMPLATE — GLOBAL STYLES
  Add as the FIRST section on the "Default article" template.
  Everything is scoped under .rub-recipe (each section below wraps its own
  content in that class) so it won't leak into the rest of the theme.
  This section itself has no visible output — just fonts + CSS.
{% endcomment %}
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700&family=Permanent+Marker&display=swap" rel="stylesheet">
<style>
  :root{
    --kraft-bg:#EDE1C8;
    --kraft-card:#F7F1E1;
    --kraft-deep:#B98D53;
    --tape:#4577A8;
    --tape-dark:#2A4D73;
    --steel:#9A9C97;
    --steel-dark:#2E2F2A;
    --ink:#201D16;
    --chili:#A6432B;
    --acid:#DEE47C;
    --acid-ink:#3A3D1E;
    --paper-line: rgba(32,29,22,0.12);
  }
  .rub-recipe *{box-sizing:border-box;}
  .rub-recipe{
    background:var(--kraft-bg);
    color:var(--ink);
    font-family:'Syne', sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .rub-recipe .wrap{max-width:1100px; margin:0 auto; padding:0 32px;}
  .rub-recipe a{color:inherit;}
  .rub-recipe h1,.rub-recipe h2,.rub-recipe h3,.rub-recipe .display{
    font-family:'Space Grotesk', sans-serif;
    text-transform:uppercase;
    letter-spacing:0.01em;
    font-weight:700;
    margin:0;
  }
  .rub-recipe .mono{font-family:'Space Mono', monospace; text-transform:uppercase; letter-spacing:0.06em;}
  .rub-recipe .tape{
    position:relative; display:inline-block; background:var(--tape); color:#152233;
    font-family:'Permanent Marker', cursive; text-transform:none; font-size:16px; line-height:1.4;
    padding:11px 22px; transform:rotate(-2deg);
    clip-path:polygon(0% 0%, 100% 0%, 98.4% 25.0%, 98.7% 50.0%, 99.8% 75.0%, 100% 100%, 0% 100%, 1.4% 75.0%, 1.5% 50.0%, 1.8% 25.0%);
    box-shadow:0 4px 10px rgba(0,0,0,0.22);
  }
  .rub-recipe .tape.alt{ background:var(--kraft-deep); color:#2b1f0f; transform:rotate(1.6deg); }
  .rub-recipe .tape.dark{ background:var(--ink); color:#EDE1C8; transform:rotate(-1deg); }
  .rub-recipe .btn{
    display:inline-flex; align-items:center; gap:10px;
    font-family:'Space Mono', monospace; text-transform:uppercase; letter-spacing:0.05em;
    font-size:14px; font-weight:700; background:var(--ink); color:var(--kraft-bg);
    padding:16px 26px; text-decoration:none; border:none; cursor:pointer;
  }
  .rub-recipe .btn:hover{background:var(--tape-dark);}
  .rub-recipe .btn.ghost{background:transparent; color:var(--ink); border:1.5px solid var(--ink);}

  /* hero */
  .rub-recipe .crumb{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.05em; color:var(--tape-dark); padding:24px 32px 0;}
  .rub-recipe .crumb a{text-decoration:none; border-bottom:1px solid var(--paper-line);}
  .rub-recipe .recipe-hero{
    display:grid; grid-template-columns:0.95fr 1.05fr; gap:56px; align-items:center;
    padding:30px 32px 60px; max-width:1100px; margin:0 auto;
  }
  .rub-recipe .recipe-photo{aspect-ratio:4/3; background:var(--steel); position:relative; overflow:hidden;}
  .rub-recipe .recipe-photo img{width:100%; height:100%; object-fit:cover; display:block;}
  .rub-recipe .recipe-photo .tape{position:absolute; top:16px; left:16px; font-size:13px; padding:8px 16px;}
  .rub-recipe .recipe-hero h1{font-size:42px; line-height:1.05; margin:16px 0 16px;}
  .rub-recipe .recipe-hero .sub{font-size:17px; line-height:1.6; color:#3a3324; max-width:48ch; margin:0 0 26px;}
  .rub-recipe .meta-row{display:flex; gap:34px; margin-bottom:30px; flex-wrap:wrap;}
  .rub-recipe .meta-item .num{font-family:'Space Grotesk'; font-weight:700; font-size:22px; display:block;}
  .rub-recipe .meta-item .lbl{font-family:'Space Mono'; font-size:11px; text-transform:uppercase; letter-spacing:0.05em; color:var(--tape-dark);}

  /* per-recipe content area (pasted per-article) */
  .rub-recipe .recipe-content{padding:20px 0 80px;}
  .rub-recipe .story-block{padding:10px 0 50px;}
  .rub-recipe .story-text{font-size:17px; line-height:1.75; color:#3a3324; max-width:68ch; margin:16px 0 0;}
  .rub-recipe .cook-grid{display:grid; grid-template-columns:0.85fr 1.3fr; gap:60px; align-items:start;}
  .rub-recipe .panel-label{font-size:22px; margin:0 0 20px; padding-bottom:14px; border-bottom:2px solid var(--ink);}
  .rub-recipe .ing-panel{background:var(--kraft-card); border:1px solid var(--paper-line); padding:30px 28px; position:sticky; top:24px;}
  .rub-recipe .ing-panel h3{font-size:18px; margin-bottom:16px;}
  .rub-recipe .ing-panel h3.second{margin-top:28px;}
  .rub-recipe .ing-panel ul{list-style:none; margin:0 0 6px; padding:0; font-size:15px; line-height:2;}
  .rub-recipe .ing-panel ul li{border-bottom:1px dashed var(--paper-line); padding:6px 0;}
  .rub-recipe .rub-callout{margin-top:24px; background:var(--ink); color:var(--kraft-bg); padding:18px 20px;}
  .rub-recipe .rub-callout p{font-family:'Syne'; font-size:14px; line-height:1.6; margin:0 0 12px; color:#e7ddc4;}
  .rub-recipe .rub-callout a{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.05em; color:var(--acid); text-decoration:none; border-bottom:1px solid var(--acid);}
  .rub-recipe .steps{counter-reset:step;}
  .rub-recipe .step{display:grid; grid-template-columns:52px 1fr; gap:20px; margin-bottom:34px;}
  .rub-recipe .step .stepnum{
    counter-increment:step; font-family:'Space Grotesk'; font-weight:700; font-size:22px;
    width:52px; height:52px; border-radius:50%; background:var(--kraft-card); border:1px solid var(--paper-line);
    display:flex; align-items:center; justify-content:center;
  }
  .rub-recipe .step .stepnum:before{content:counter(step);}
  .rub-recipe .step h4{font-size:18px; margin:2px 0 8px;}
  .rub-recipe .step p{font-size:15.5px; line-height:1.7; color:#3a3324; margin:0;}
  .rub-recipe .tip-box{margin:44px 0 8px; background:var(--acid); padding:26px 28px; position:relative;}
  .rub-recipe .tip-box .tape{position:absolute; top:-16px; left:24px; font-size:13px; padding:8px 16px;}
  .rub-recipe .tip-box p{font-family:'Syne'; font-size:16px; line-height:1.6; color:var(--acid-ink); margin:10px 0 0;}

  /* fallback styling for plain rich-text content — this is what actually
     renders when you use the editor's normal Heading/List/Quote buttons
     instead of pasting custom HTML (which Shopify strips on save) */
  .rub-recipe .recipe-content > p:first-of-type{
    font-size:17px; line-height:1.75; color:#3a3324; max-width:68ch; margin:0 0 20px;
  }
  .rub-recipe .recipe-content h2{
    font-family:'Space Grotesk'; text-transform:uppercase; font-weight:700;
    font-size:26px; margin:48px 0 20px; padding-bottom:14px;
    border-bottom:2px solid var(--ink);
  }
  .rub-recipe .recipe-content h3{
    font-family:'Space Mono'; text-transform:uppercase; font-weight:700;
    font-size:14px; letter-spacing:0.05em; color:var(--tape-dark); margin:28px 0 12px;
  }
  .rub-recipe .recipe-content p{font-size:16px; line-height:1.75; color:#3a3324; margin:0 0 16px;}

  .rub-recipe .recipe-content ul{
    list-style:none; padding-left:0; margin:20px 0 32px;
  }
  .rub-recipe .recipe-content ul > li{
    padding:10px 0 10px 22px; border-bottom:1px dashed var(--paper-line);
    position:relative; font-size:15px;
  }
  .rub-recipe .recipe-content ul > li::before{
    content:"—"; position:absolute; left:0; color:var(--chili);
  }

  .rub-recipe .recipe-content ol{
    list-style:none; counter-reset:step; padding-left:0; margin:36px 0;
  }
  .rub-recipe .recipe-content ol > li{
    position:relative; padding-left:70px; margin-bottom:28px; min-height:52px;
  }
  .rub-recipe .recipe-content ol > li::before{
    counter-increment:step; content:counter(step);
    position:absolute; left:0; top:0;
    width:52px; height:52px; border-radius:50%;
    background:var(--kraft-card); border:1px solid var(--paper-line);
    font-family:'Space Grotesk'; font-weight:700; font-size:20px;
    line-height:50px; text-align:center;
  }

  .rub-recipe .recipe-content blockquote{
    background:var(--acid); color:var(--acid-ink); padding:26px 28px;
    margin:44px 0; border:none; font-family:'Syne'; font-size:16px; line-height:1.6;
  }
  .rub-recipe .recipe-content blockquote::before{
    content:"Pro tip"; display:block; font-family:'Permanent Marker';
    background:var(--ink); color:var(--acid); font-size:13px;
    padding:8px 16px; margin-bottom:14px; width:fit-content;
  }
  .rub-recipe .recipe-content blockquote p{color:var(--acid-ink); margin:0;}

  /* related recipes */
  .rub-recipe .related{padding:20px 0 90px;}
  .rub-recipe .section-head{margin-bottom:34px;}
  .rub-recipe .section-head h2{font-size:30px; margin:14px 0 0;}
  .rub-recipe .recipes-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:26px;}
  .rub-recipe .recipe-card{background:var(--kraft-card); border:1px solid var(--paper-line);}
  .rub-recipe .recipe-img{aspect-ratio:4/3; background:var(--steel); position:relative; overflow:hidden; display:flex; align-items:flex-end; padding:14px;}
  .rub-recipe .recipe-img img{position:absolute; inset:0; width:100%; height:100%; object-fit:cover;}
  .rub-recipe .recipe-body{padding:20px 18px 26px;}
  .rub-recipe .recipe-body h3{font-size:18px; margin:0 0 8px;}
  .rub-recipe .recipe-body p{font-size:14px; color:#5c5340; margin:0 0 14px; line-height:1.55;}
  .rub-recipe .recipe-link{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.04em; text-decoration:none; border-bottom:1px solid var(--ink);}

  /* footer */
  .rub-recipe footer{background:var(--steel-dark); color:var(--kraft-bg); padding:56px 0 34px;}
  .rub-recipe .foot-top{display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:40px; flex-wrap:wrap; gap:30px;}
  .rub-recipe .foot-logo{font-family:'Space Grotesk'; font-weight:700; font-size:24px; text-transform:uppercase;}
  .rub-recipe .foot-links{display:flex; gap:60px; flex-wrap:wrap;}
  .rub-recipe .foot-col h4{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.06em; color:#B7B6AE; margin:0 0 14px;}
  .rub-recipe .foot-col a{display:block; font-size:14px; text-decoration:none; color:var(--kraft-bg); margin-bottom:8px; opacity:0.9;}
  .rub-recipe .foot-bottom{border-top:1px solid rgba(255,255,255,0.15); padding-top:22px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:14px;}
  .rub-recipe .foot-bottom .sign{font-family:'Permanent Marker'; font-size:20px; color:var(--kraft-bg);}
  .rub-recipe .foot-bottom .copy{font-family:'Space Mono'; font-size:11px; color:#8f8e86; text-transform:uppercase;}

  @media (max-width:860px){
    .rub-recipe .recipe-hero{grid-template-columns:1fr;}
    .rub-recipe .cook-grid{grid-template-columns:1fr;}
    .rub-recipe .ing-panel{position:static;}
    .rub-recipe .recipes-grid{grid-template-columns:1fr;}
    .rub-recipe .foot-top{flex-direction:column;}
  }
</style>

