{% comment %}
  THE RUB — GLOBAL STYLES
  Add this as the FIRST/topmost section on the page.
  It has no visible content — it just loads the fonts and CSS classes
  that every other section below it depends on (.tape, .btn, .wrap, etc).
  Do not delete or reorder this above the others.

  UPDATED: removed a leftover blanket "section { padding: 60px 0; }" rule
  that was stacking with each section's own top/bottom padding and causing
  extra gaps between sections. Each section now has explicit top/bottom
  padding instead of relying on a shared default.
{% endcomment %}
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700&family=Permanent+Marker&display=swap" rel="stylesheet">
<style>
  :root{
    --kraft-bg:#EDE1C8;
    --kraft-card:#F7F1E1;
    --kraft-deep:#B98D53;
    --tape:#4577A8;
    --tape-dark:#2A4D73;
    --steel:#9A9C97;
    --steel-dark:#2E2F2A;
    --ink:#201D16;
    --chili:#A6432B;
    --acid:#DEE47C;
    --acid-ink:#3A3D1E;
    --paper-line: rgba(32,29,22,0.12);
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--kraft-bg);
    color:var(--ink);
    font-family:'Syne', sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:1100px; margin:0 auto; padding:0 32px;}
  a{color:inherit;}

  h1,h2,h3,.display{
    font-family:'Space Grotesk', sans-serif;
    text-transform:uppercase;
    letter-spacing:0.01em;
    font-weight:700;
    margin:0;
  }
  .mono{
    font-family:'Space Mono', monospace;
    text-transform:uppercase;
    letter-spacing:0.06em;
  }
  .marker{
    font-family:'Permanent Marker', cursive;
    text-transform:none;
    letter-spacing:0.01em;
  }

  /* ---- signature element: torn tape strip ---- */
  .tape{
    position:relative;
    display:inline-block;
    background:var(--tape);
    color:#152233;
    font-family:'Permanent Marker', cursive;
    text-transform:none;
    font-size:20px;
    line-height:1.5;
    padding:14px 26px;
    transform:rotate(-2deg);
    clip-path:polygon(0% 0%, 100% 0%, 98.4% 25.0%, 98.7% 50.0%, 99.8% 75.0%, 100% 100%, 0% 100%, 1.4% 75.0%, 1.5% 50.0%, 1.8% 25.0%);
    box-shadow:0 4px 10px rgba(0,0,0,0.22);
  }
  .tape.alt{ background:var(--kraft-deep); color:#2b1f0f; transform:rotate(1.6deg); }
  .tape.dark{ background:var(--ink); color:#EDE1C8; transform:rotate(-1deg); }

  /* ---- nav ---- */
  nav{
    display:flex; align-items:center; justify-content:space-between;
    padding:26px 32px;
    max-width:1100px; margin:0 auto;
  }
  .logo{
    font-family:'Space Grotesk', sans-serif;
    font-weight:700;
    font-size:22px;
    text-transform:uppercase;
    letter-spacing:0.02em;
    display:flex; align-items:center; gap:10px;
  }
  .logo .dot{
    width:8px; height:8px; border-radius:50%; background:var(--chili); display:inline-block;
  }
  .navlinks{display:flex; gap:34px; font-family:'Space Mono',monospace; font-size:13px; text-transform:uppercase; letter-spacing:0.05em;}
  .navlinks a{text-decoration:none; border-bottom:1px solid transparent;}
  .navlinks a:hover{border-color:var(--ink);}

  /* ---- hero ---- */
  .hero{
    display:grid; grid-template-columns:1.05fr 0.95fr; gap:56px;
    align-items:center;
    padding:36px 32px 90px;
    max-width:1100px; margin:0 auto;
  }
  .hero h1{font-size:56px; line-height:1.02; margin:18px 0 22px;}
  .hero h1 span{color:var(--chili);}
  .hero p.sub{
    font-size:18px; line-height:1.55; max-width:46ch; color:#3a3324; margin:0 0 30px;
  }
  .btn{
    display:inline-flex; align-items:center; gap:10px;
    font-family:'Space Mono', monospace; text-transform:uppercase; letter-spacing:0.05em;
    font-size:14px; font-weight:700;
    background:var(--ink); color:var(--kraft-bg);
    padding:16px 26px; text-decoration:none; border:none; cursor:pointer;
  }
  .btn:hover{background:var(--tape-dark);}
  .btn.ghost{background:transparent; color:var(--ink); border:1.5px solid var(--ink);}

  .hero-photo-frame{
    position:relative;
    background:var(--steel);
    padding:26px;
    transform:rotate(1deg);
  }
  .hero-photo-frame img{
    display:block; width:100%; height:auto;
    filter:saturate(0.92) contrast(1.02);
    border:1px solid rgba(0,0,0,0.15);
  }
  .hero-photo-frame .cap{
    position:absolute; bottom:-16px; left:26px;
  }

  /* ---- section shared ---- */
  section{padding:0;}
  #shop{padding-top:120px; padding-bottom:70px;}
  #recipe-collection{padding-top:100px; padding-bottom:70px;}
  #story{padding-top:100px; padding-bottom:110px;}
  .section-head{margin-bottom:40px;}
  .section-head h2{font-size:34px; margin:14px 0 0;}
  .divider{border:none; border-top:1px solid var(--paper-line); margin:0;}

  /* ---- product ---- */
  .product{
    display:grid; grid-template-columns:0.8fr 1.2fr; gap:56px; align-items:start;
  }
  .product-card{
    background:var(--kraft-card); border:1px solid var(--paper-line); padding:40px 34px; position:relative;
  }
  .pouch{
    width:100%; aspect-ratio:3/4; background:linear-gradient(180deg,#D9C69C,#C9AF7D);
    border:1px solid rgba(0,0,0,0.15);
    display:flex; align-items:center; justify-content:center; flex-direction:column; gap:6px;
    position:relative;
  }
  .pouch .pouch-logo{font-family:'Space Grotesk'; font-weight:700; text-transform:uppercase; font-size:26px;}
  .pouch .pouch-sub{font-family:'Space Mono'; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:#5b4526;}
  .price-row{display:flex; align-items:baseline; gap:14px; margin:26px 0 18px;}
  .price{font-family:'Space Grotesk'; font-weight:700; font-size:30px;}
  .was{font-family:'Space Mono'; font-size:14px; color:#8a7c5e; text-decoration:line-through;}
  .sizes{display:flex; gap:10px; margin-bottom:26px;}
  .size-pill{
    font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.04em;
    border:1.5px solid var(--ink); padding:8px 14px; cursor:pointer;
  }
  .size-pill.active{background:var(--ink); color:var(--kraft-bg);}
  .product h3{font-size:30px; margin:0 0 6px;}
  .product .kicker{font-family:'Space Mono'; font-size:13px; color:var(--tape-dark); margin-bottom:10px; display:block;}
  .product p{font-size:16px; line-height:1.7; color:#3a3324; max-width:52ch; margin:0 0 26px;}
  .feat-list{list-style:none; padding:0; margin:0 0 30px; font-family:'Space Mono'; font-size:13px; text-transform:uppercase; display:flex; flex-direction:column; gap:10px;}
  .feat-list li:before{content:"— "; color:var(--chili);}

  /* ---- recipes ---- */
  .recipes-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:26px;}
  .recipe-card{background:var(--kraft-card); border:1px solid var(--paper-line);}
  .recipe-img{
    aspect-ratio:4/3; background:var(--steel); position:relative; overflow:hidden;
    display:flex; align-items:flex-end; padding:14px;
  }
  .recipe-body{padding:20px 18px 26px;}
  .recipe-body h3{font-size:19px; margin:0 0 8px;}
  .recipe-body p{font-size:14px; color:#5c5340; margin:0 0 14px; line-height:1.55;}
  .recipe-link{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.04em; text-decoration:none; border-bottom:1px solid var(--ink);}

  /* ---- perfect for: scrolling band ---- */
  .perfect-for{padding:0;}
  .perfect-for-stage{position:relative;}
  .marquee-outer{
    overflow:hidden;
    background:var(--steel-dark);
    padding:24px 0;
    width:100%;
  }
  .marquee-track{
    display:flex; align-items:center; gap:26px;
    width:max-content;
    animation:marquee 24s linear infinite;
    white-space:nowrap;
  }
  .marquee-outer:hover .marquee-track{animation-play-state:paused;}
  .marquee-track span.item{
    font-family:'Space Grotesk'; font-weight:700; text-transform:uppercase;
    font-size:24px; letter-spacing:0.01em; color:var(--kraft-bg);
  }
  .marquee-track span.dot{color:var(--chili); font-size:15px;}
  .perfect-tape{
    position:absolute; top:-15px; left:40px;
    font-size:15px;
    padding:10px 20px;
    transform:rotate(-3deg);
    z-index:5;
  }
  @keyframes marquee{
    from{transform:translateX(0);}
    to{transform:translateX(-50%);}
  }

  /* ---- quote ---- */
  .quote-section{
    background:var(--acid);
    padding:70px 0;
    position:relative;
    overflow:hidden;
  }
  .quote-inner{
    max-width:760px; margin:0 auto; padding:0 32px; position:relative; text-align:center;
    min-height:280px; display:flex; flex-direction:column; align-items:center; justify-content:center;
    overflow:hidden;
  }
  .quote-mark{
    font-family:'Space Grotesk'; font-weight:700; font-size:160px;
    color:var(--acid-ink); opacity:0.14; line-height:1;
    position:absolute; top:-24px; left:50%; transform:translateX(-50%);
    pointer-events:none; user-select:none;
  }
  .quote-slide{
    transition:transform 0.35s ease, opacity 0.35s ease;
    width:100%;
  }
  .quote-text{
    font-family:'Syne'; font-weight:700; font-size:38px; line-height:1.3;
    color:var(--acid-ink); margin:0 0 26px; position:relative;
  }
  .quote-attr-row{display:flex; align-items:center; justify-content:center; gap:14px;}
  .quote-attr{font-family:'Space Mono'; font-size:14px; text-transform:uppercase; letter-spacing:0.05em; color:var(--acid-ink);}
  .quote-tag{
    background:var(--ink); color:var(--acid); font-family:'Space Mono'; font-size:11px;
    text-transform:uppercase; letter-spacing:0.05em; padding:5px 12px; transform:rotate(-2deg);
  }
  .quote-arrow{
    position:absolute; top:50%; transform:translateY(-50%);
    width:46px; height:46px; border-radius:50%; border:none;
    background:var(--ink); color:var(--acid);
    font-size:26px; line-height:1; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    z-index:3;
  }
  .quote-arrow:hover{background:var(--acid-ink);}
  .quote-arrow.left{left:24px;}
  .quote-arrow.right{right:24px;}
  .quote-dots{display:flex; gap:8px; justify-content:center; margin-top:22px;}
  .quote-dots span{width:8px; height:8px; border-radius:50%; background:rgba(58,61,30,0.25); cursor:pointer;}
  .quote-dots span.active{background:var(--acid-ink);}
  /* ---- footer ---- */
  footer{background:var(--steel-dark); color:var(--kraft-bg); padding:56px 0 34px;}
  .foot-top{display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:40px; flex-wrap:wrap; gap:30px;}
  .foot-logo{font-family:'Space Grotesk'; font-weight:700; font-size:24px; text-transform:uppercase;}
  .foot-links{display:flex; gap:60px; flex-wrap:wrap;}
  .foot-col h4{font-family:'Space Mono'; font-size:12px; text-transform:uppercase; letter-spacing:0.06em; color:#B7B6AE; margin:0 0 14px;}
  .foot-col a{display:block; font-size:14px; text-decoration:none; color:var(--kraft-bg); margin-bottom:8px; opacity:0.9;}
  .foot-bottom{border-top:1px solid rgba(255,255,255,0.15); padding-top:22px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:14px;}
  .foot-bottom .sign{font-family:'Permanent Marker'; font-size:20px; color:var(--kraft-bg);}
  .foot-bottom .copy{font-family:'Space Mono'; font-size:11px; color:#8f8e86; text-transform:uppercase;}

  @media (max-width:860px){
    .hero{grid-template-columns:1fr; padding-bottom:60px;}
    .hero h1{font-size:38px;}
    .ing-grid{grid-template-columns:1fr;}
    .product{grid-template-columns:1fr;}
    .recipes-grid{grid-template-columns:1fr;}
    .foot-top{flex-direction:column;}
  }
</style>
