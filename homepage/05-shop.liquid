{% comment %}
  THE RUB — SHOP / PRODUCT TEASER
{% endcomment %}
<section id="shop" class="wrap">
  <div class="product">
    <div class="product-card">
      <span class="tape" style="position:absolute; top:-14px; right:18px; z-index:2;">Bestseller</span>
      <div class="pouch">
        <div class="pouch-logo">The rub</div>
        <div class="pouch-sub">6 oz &middot; net wt</div>
      </div>
    </div>
    <div>
      <span class="kicker mono">Original blend</span>
      <h3>The rub, 6 oz pouch</h3>
      <p>The one that started it all. Rub it on wings, ribs, potatoes, or your finger straight out of the bag. We won't tell.</p>
      <ul class="feat-list">
        <li>No MSG, no anti-caking agents</li>
        <li>Small-batch, hand mixed</li>
        <li>Goes on everything, we've checked</li>
      </ul>
      <div class="price-row">
        <span class="price">$12</span>
        <span class="was">$15</span>
      </div>
      <div class="sizes">
        <span class="size-pill active">6 oz</span>
        <span class="size-pill">12 oz</span>
        <span class="size-pill">Refill bag</span>
      </div>
      <button class="btn">Add to cart</button>
    </div>
  </div>
</section>
